/* app.wxss - 全局样式 */
page {
  background-color: #0f0f1a;
  color: #e0e0e0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  min-height: 100vh;
}

/* 主色调 */
.primary-color { color: #6c5ce7; }
.accent-color  { color: #a29bfe; }

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #6c5ce7, #a29bfe);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary[disabled] {
  opacity: 0.4;
}

.btn-secondary {
  background: rgba(255,255,255,0.1);
  color: #a29bfe;
  border: 1rpx solid rgba(108,92,231,0.4);
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
}

/* 卡片 */
.card {
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
