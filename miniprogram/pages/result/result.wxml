<!--pages/result/result.wxml - 结果页-->
<view class="container">
  <!-- 成功图标 -->
  <view class="success-icon">
    <text class="emoji">✅</text>
  </view>
  <text class="success-title">音频提取完成</text>

  <!-- 音频信息卡片 -->
  <view class="card">
    <view class="audio-info">
      <text class="audio-icon">🎵</text>
      <view class="audio-meta">
        <text class="audio-name">audio_{{taskId}}.mp3</text>
        <text class="audio-size">{{audioSizeText}}</text>
      </view>
    </view>

    <!-- 播放按钮 -->
    <view class="play-btn {{isPlaying ? 'playing' : ''}}" bindtap="onTogglePlay">
      <text class="play-icon">{{isPlaying ? '⏸' : '▶'}}</text>
      <text class="play-text">{{isPlaying ? '暂停' : '播放'}}</text>
    </view>
  </view>

  <!-- 下载进度 -->
  <view wx:if="{{isDownloading}}" class="download-progress">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{downloadProgress}}%;"></view>
    </view>
    <text class="progress-text">下载中 {{downloadProgress}}%</text>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button class="btn-primary" bindtap="onDownload" disabled="{{isDownloading}}">
      {{isDownloading ? '下载中...' : '⬇ 保存到本地'}}
    </button>
    <button class="btn-secondary" bindtap="onProcessAnother">
      🔄 再提取一个
    </button>
  </view>

  <!-- 底部提示 -->
  <view class="tips">
    <text class="tip-text">💡 保存后可通过文件管理器找到音频</text>
  </view>
</view>
