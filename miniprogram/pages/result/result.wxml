<!--pages/result/result.wxml - 结果页-->
<view class="container">
  <!-- 成功图标 -->
  <view class="success-icon">
    <text class="emoji">✅</text>
  </view>
  <text class="success-title">音频提取完成</text>

  <!-- 音频加载中 -->
  <view wx:if="{{isLoading}}" class="card">
    <view style="padding: 40rpx; text-align: center;">
      <view class="spinner" style="margin: 0 auto 20rpx;"></view>
      <text class="progress-message">正在加载音频...</text>
    </view>
  </view>

  <!-- 音频加载失败 -->
  <view wx:elif="{{loadError}}" class="card">
    <view style="padding: 40rpx; text-align: center;">
      <text class="emoji">😕</text>
      <text class="error-msg">{{loadError}}</text>
      <button class="btn-primary" bindtap="onProcessAnother" style="margin-top: 30rpx;">返回重试</button>
    </view>
  </view>

  <!-- 音频信息卡片 -->
  <view wx:else class="card">
    <view class="audio-info">
      <text class="audio-icon">🎵</text>
      <view class="audio-meta">
        <input
          class="audio-name-input"
          value="{{filename}}"
          bindinput="onFilenameInput"
          maxlength="100"
        />
        <text class="audio-size">{{audioSizeText}}</text>
      </view>
    </view>

    <!-- 播放按钮 -->
    <view class="play-btn {{isPlaying ? 'playing' : ''}}" bindtap="onTogglePlay">
      <text class="play-icon">{{isPlaying ? '⏸' : '▶'}}</text>
      <text class="play-text">{{isPlaying ? '暂停' : '播放'}}</text>
    </view>
  </view>

  <!-- 转发进度 -->
  <view wx:if="{{isForwarding}}" class="download-progress">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{forwardProgress}}%;"></view>
    </view>
    <text class="progress-text">准备转发 {{forwardProgress}}%</text>
  </view>

  <!-- 操作按钮 -->
  <view wx:if="{{!isLoading && !loadError}}" class="actions">
    <button class="btn-primary" bindtap="onForwardToChat" disabled="{{isForwarding}}">
      {{isForwarding ? '准备转发...' : '↗ 转发到微信'}}
    </button>
    <button class="btn-secondary" bindtap="onProcessAnother">
      🔄 再提取一个
    </button>
  </view>

  <!-- 底部提示 -->
  <view wx:if="{{!isLoading && !loadError}}" class="tips">
    <text class="tip-text">💡 先输入文件名，再点击转发到微信</text>
  </view>
</view>
