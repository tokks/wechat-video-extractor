<!--pages/index/index.wxml - 首页-->
<view class="container">
  <!-- 顶部标题区 -->
  <view class="header">
    <view class="logo-icon">
      <text class="iconfont">🎬</text>
    </view>
    <text class="title">视频提取音频</text>
    <text class="subtitle">支持聊天文件 / 相册视频</text>
  </view>

  <!-- ========== 链接解析功能（审核期间临时屏蔽，通过后恢复） ==========
  <view class="section">
    <view class="section-title">
      <text class="section-num">1</text>
      <text>粘贴视频链接</text>
    </view>
    <view class="link-input-wrap">
      <textarea
        class="link-input"
        placeholder="粘贴抖音、快手、B站、小红书等链接"
        placeholder-class="placeholder"
        value="{{linkInput}}"
        bindinput="onLinkInput"
        auto-height
        maxlength="500"
      />
      <view class="link-actions">
        <text class="action-btn" bindtap="onPasteLink">📋 粘贴</text>
        <text wx:if="{{linkInput}}" class="action-btn" bindtap="onClearLink">✕ 清除</text>
      </view>
    </view>
    <view class="platform-tags">
      <text wx:for="{{supportedPlatforms}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
    <button class="btn-primary" bindtap="onParseLink">解析并提取音频</button>
  </view>

  <view class="divider">
    <view class="divider-line"></view>
    <text class="divider-text">或</text>
    <view class="divider-line"></view>
  </view>
  ========== 链接解析功能结束 ========== -->

  <!-- 从本地选择视频 -->
  <view class="section">
    <view class="section-title">
      <text class="section-num">1</text>
      <text>从本地选择视频</text>
    </view>
    <view class="upload-options">
      <view class="upload-card" bindtap="onChooseFromChat">
        <text class="upload-icon">💬</text>
        <text class="upload-label">微信聊天文件</text>
        <text class="upload-desc">从聊天记录中选择视频</text>
      </view>
      <view class="upload-card" bindtap="onChooseFromAlbum">
        <text class="upload-icon">📁</text>
        <text class="upload-label">相册视频</text>
        <text class="upload-desc">支持大于 1GB 的视频</text>
      </view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer-note">
    <text>音频将以 MP3 格式输出（192kbps）</text>
  </view>
</view>
