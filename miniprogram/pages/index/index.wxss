/* pages/index/index.wxss - 首页样式 */
.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #6c5ce7, #a29bfe);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(108,92,231,0.3);
}

.iconfont {
  font-size: 56rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
}

.section {
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ccc;
}

.section-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: #6c5ce7;
  color: #fff;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.link-input-wrap {
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.link-input {
  width: 100%;
  min-height: 80rpx;
  color: #e0e0e0;
  font-size: 28rpx;
  line-height: 1.6;
}

.placeholder {
  color: #555;
}

.link-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 12rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #a29bfe;
  padding: 6rpx 20rpx;
  border: 1rpx solid rgba(108,92,231,0.3);
  border-radius: 20rpx;
}

.platform-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tag {
  font-size: 22rpx;
  color: #a29bfe;
  background: rgba(108,92,231,0.15);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.divider {
  display: flex;
  align-items: center;
  padding: 20rpx 60rpx;
  margin: 10rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255,255,255,0.1);
}

.divider-text {
  padding: 0 24rpx;
  color: #555;
  font-size: 24rpx;
}

.upload-options {
  display: flex;
  gap: 20rpx;
}

.upload-card {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.05);
}

.upload-card:active {
  background: rgba(108,92,231,0.1);
  border-color: rgba(108,92,231,0.3);
}

.upload-icon {
  font-size: 52rpx;
  margin-bottom: 16rpx;
}

.upload-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #ddd;
  margin-bottom: 8rpx;
}

.upload-desc {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.footer-note {
  text-align: center;
  padding: 40rpx;
  color: #444;
  font-size: 24rpx;
}

/* 更多方式入口 */
.more-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  margin: 8rpx 0;
}

.more-text {
  font-size: 26rpx;
  color: #555;
  margin-right: 12rpx;
}

.more-arrow {
  font-size: 20rpx;
  color: #555;
  transition: transform 0.2s;
}

.arrow-up {
  transform: rotate(180deg);
}
